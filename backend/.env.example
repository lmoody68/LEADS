# L.E.A.D.S. backend environment.
# Copy to ".env" and fill in any ONE key to enable LLM synthesis.
# With NO key configured, the app still works fully via the EXTRACTIVE fallback
# (returns the top retrieved passages + citations as the answer).

# Free-first LLM cascade: Groq -> Gemini -> Claude (Anthropic).
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional model overrides (sensible free-tier defaults are used if blank).
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# CORS origin for the Vite dev server.
FRONTEND_ORIGIN=http://localhost:5173

# CourtListener (Free Law Project) — live public court opinions for deep research.
# OPTIONAL: with a token you get much higher rate limits. WITHOUT a token the app
# still works (anonymous queries are heavily rate-limited; on HTTP 429 the
# pipeline gracefully falls back to the seeded statute corpus).
# Get a free token at https://www.courtlistener.com/help/api/rest/
COURTLISTENER_API_TOKEN=
